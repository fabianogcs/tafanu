generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // 🚀 O Prisma só vai usar a DIRECT_URL se essa linha existir!
}
enum EventType {
  WHATSAPP
  PHONE
  INSTAGRAM
  FACEBOOK
  TIKTOK
  WEBSITE
  MAP
  SHOPEE
  MERCADOLIVRE
  SHEIN
  IFOOD
  VIEW
}
enum Role {
  VISITANTE
  CLIENTE
  ADMIN
  AFILIADO   // ⬅️ Faltava esse!
  ASSINANTE
}
enum LayoutType {
  editorial
  urban
  businessList
  showroom
  influencer
}

enum PlanType {
  monthly
  quarterly
  yearly
}

// --- TABELA DE USUÁRIOS ---
model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime? 
  image           String?   
  password        String?
  commissions    Commission[]  @relation("AffiliateCommissions")
  withdrawals    Withdrawal[]  @relation("AffiliateWithdrawals")
  referralLogs   ReferralLog[] @relation("AffiliateLogs")
  isReferredBy   ReferralLog?  @relation("ReferredUser")
  
 role            Role      @default(VISITANTE)
  referralCode    String?   @unique 
  affiliateId     String?           
  affiliate       User?     @relation("AffiliateToUser", fields: [affiliateId], references: [id])
  affiliateSince  DateTime? 
  lastPayoutDate  DateTime?
  lastPrice       Float?    @default(0)    
  referrals       User[]    @relation("AffiliateToUser")
  document        String?   @unique
  phone           String?
  createdAt       DateTime  @default(now())
  isBanned        Boolean   @default(false)

  accounts      Account[] 
  sessions      Session[] 

  businesses    Business[] 
  favorites     Favorite[] 
  comments      Comment[]
}

// --- TABELA DE NEGÓCIOS ---
model Business {
  id                  String         @id @default(cuid())
  name                String
  slug                String         @unique
  description         String?        @db.Text
 theme      String         @default("showroom_nordic")
  layout     LayoutType     @default(showroom)
  category            String
 subcategory         String[]       @default([])
  keywords            String[]       @default([])
  
  // Contadores Desnormalizados (Performance)
  whatsapp_clicks     Int @default(0)  
  phone_clicks        Int @default(0)  
  instagram_clicks    Int @default(0)
  facebook_clicks     Int @default(0)
  tiktok_clicks       Int @default(0)
  website_clicks      Int @default(0)
  shopee_clicks       Int @default(0)
  mercadolivre_clicks Int @default(0)
  shein_clicks        Int @default(0)
  ifood_clicks        Int @default(0)
  map_clicks          Int @default(0) 
  views               Int            @default(0) // Centralizado aqui

// Mídia
  imageUrl            String?        @db.Text 
  gallery             String[]       @default([])
  videos              String[]       @default([]) // 🚀 NOVO: Gaveta para os links de vídeos (YouTube/Insta/TikTok)
  mediaFeed           Json[]         @default([])

  // Tags e Conteúdo Extra
  urban_tag           String?
  luxe_quote          String?
  comercial_badge     String?
  showroom_collection String?
  features            String[]       @default([])
  faqs                Json[]         @default([])

  // Localização e Contato
  address             String?
  number              String?        
  complement          String?       
  cep                 String?
  neighborhood        String?        
  city                String?   
  state               String?   
  latitude            Float?
  longitude           Float?
  whatsapp            String?
  phone               String?
  website             String?
  instagram           String?
  facebook            String?
  tiktok              String?
  shopee              String?
  mercadoLivre        String?
  shein               String?
  ifood               String?

  hasDelivery         Boolean        @default(false)

  // 💰 Dados da Assinatura Deste Negócio Específico
  planType            PlanType?      // ⬅️ NOVO: Transferido do User
  subscriptionStatus String?        @default("inactive") // ⬅️ NOVO: 'active', 'past_due', 'cancelled'
  expiresAt           DateTime?      // ⬅️ NOVO: Transferido do User
  mpSubscriptionId    String?        // ⬅️ NOVO: Transferido do User

  etapaFunil         Int            @default(1)
  
  published           Boolean        @default(true) 
  isActive            Boolean        @default(true) 
  createdAt           DateTime       @default(now()) // Centralizado aqui
  updatedAt           DateTime       @updatedAt

  userId              String
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  hours               BusinessHour[]
  favorites           Favorite[]
  reports             Report[]
  comments            Comment[]
  analytics           AnalyticsEvent[]

  // 🚀 ÍNDICES DE ALTA PERFORMANCE
  @@index([category])
  @@index([name])
  @@index([neighborhood])
  @@index([city])
  @@index([views])       
  @@index([createdAt])   

  // Índices Compostos (Acelera buscas tipo: "Pizzaria em São Paulo")
  @@index([city, category])            
  @@index([city, neighborhood])        
  @@index([city, isActive, published]) 
  @@index([category, isActive, published]) 
  @@index([name, city])
}

model BusinessHour {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  dayOfWeek   Int      
  openTime    String   
  closeTime   String   
  isClosed    Boolean  @default(false)
  @@index([businessId])
}

model Favorite {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
}

model Report {
  id          String   @id @default(cuid())
  reason      String   
  details     String?  
  status      String   @default("PENDING") 
  createdAt   DateTime @default(now())
  businessId  String
  reportedBy  String?
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([reportedBy])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model Comment {
  id         String   @id @default(cuid())
  content    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isFlagged  Boolean  @default(false)
  flaggedBy  String?
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentReplies")

  @@index([businessId])
  @@index([userId])
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
 eventType   EventType
  createdAt   DateTime @default(now())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt]) // Busca range de datas por loja (Muito rápido)
  @@index([eventType])
}
// --- SISTEMA DE AFILIADOS PROFISSIONAL ---

enum CommissionStatus {
  PENDING    // Aguardando prazo de garantia (ex: 7 dias)
  AVAILABLE  // Liberado para o afiliado pedir saque
  PAID       // Você já transferiu o dinheiro
  CANCELLED  // Cliente pediu estorno ou assinatura falhou
}

model ReferralLog {
  id          String   @id @default(cuid())
  affiliateId String   // ID do User que indicou
  referredId  String   @unique // ID do User que foi indicado
  createdAt   DateTime @default(now())
  
  affiliate   User     @relation("AffiliateLogs", fields: [affiliateId], references: [id])
  referred    User     @relation("ReferredUser", fields: [referredId], references: [id])

  @@index([affiliateId])
}

model Commission {
  id            String           @id @default(cuid())
  affiliateId   String
  userId        String           // Cliente que pagou
  amount        Float            // Valor da comissão (ex: 7.98)
  orderAmount   Float            // Valor total da venda (ex: 39.90)
  status        CommissionStatus @default(PENDING)
  description   String?          // Ex: "Mensalidade Março - Cliente X"
  createdAt     DateTime         @default(now())
  releaseDate   DateTime         // Data que o valor fica disponível (createdAt + 7 dias)

  // ⬅️ NOVO: Relacionamento para saber em qual saque esta comissão foi paga
  withdrawalId   String?          
  withdrawal     Withdrawal?      @relation(fields: [withdrawalId], references: [id])
  
  affiliate     User             @relation("AffiliateCommissions", fields: [affiliateId], references: [id])

  @@index([affiliateId])
  @@index([status])
  @@index([withdrawalId]) 
}

model Withdrawal {
  id          String   @id @default(cuid())
  affiliateId String
  amount      Float
  pixKey      String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
  paidAt      DateTime?

  affiliate   User     @relation("AffiliateWithdrawals", fields: [affiliateId], references: [id])
  commissions Commission[] // ⬅️ NOVO: Lista de comissões que compõem este saque

  @@index([affiliateId])
}